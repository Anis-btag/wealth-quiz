{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css",  "use": "@vercel/static" },
    { "src": "*.js",   "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/style.css",   "dest": "/style.css"   },
    { "src": "/app.js",      "dest": "/app.js"       },
    { "src": "/supabase.js", "dest": "/supabase.js"  },
    { "src": "/(.*)",        "dest": "/index.html"   }
  ]
}
